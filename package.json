{
  "name": "citizen-gateway",
  "description": "Express Gateway Instance Bootstraped from Command Line",
  "repository": {},
  "license": "UNLICENSED",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "kill-all": "kill -9 $(lsof -t -i:3520);",
    "local:win:dev": "SET NODE_ENV=local& nodemon server.js",
    "local:ubu:dev": "npm run kill-all; NODE_ENV=local nodemon server.js",
    "local:ubu:staging": "kill -9 $(lsof -t -i:3520); NODE_ENV=staging nodemon server.js",
    "staging:win:dev": "SET NODE_ENV=local& nodemon server.js",
    "staging:ubu:dev": "NODE_ENV=staging node server.js",
    "prod:unu": "npx cross-env NODE_ENV=prod nodemon server.js",
    "staging:unu": "npx cross-env NODE_ENV=staging nodemon server.js",
    "prod:live": "kill -9 $(lsof -t -i:3520);NODE_ENV=live nodemon server.js"
  },
  "dependencies": {
    "@aws-sdk/client-pinpoint": "^3.462.0",
    "@aws-sdk/client-s3": "^3.425.0",
    "@aws-sdk/client-ses": "^3.462.0",
    "@aws-sdk/s3-request-presigner": "^3.425.0",
    "@joi/date": "^2.1.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.4.0",
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "country-state-city": "^3.1.4",
    "countrycitystatejson": "^21.2.2301",
    "cross-env": "^7.0.3",
    "custom-env": "^2.0.1",
    "ejs": "^3.1.9",
    "exceljs": "^4.3.0",
    "express": "^4.21.2",
    "express-gateway": "^1.16.11",
    "firebase-admin": "^11.5.0",
    "geoip-lite": "^2.0.2",
    "iso-3166-2": "^1.0.0",
    "joi": "^17.8.3",
    "jsonwebtoken": "^9.0.3",
    "logger": "^0.0.1",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "pg": "^8.9.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.28.1",
    "sequelize-cli": "^6.6.0",
    "serverless-http": "^3.2.0",
    "stripe": "^11.16.0",
    "swagger-ui-express": "^4.6.2",
    "tz-lookup": "^6.1.25",
    "xlsx": "^0.18.5",
    "xml2js": "^0.5.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  },
  "keywords": [],
